export DB_HOST="localhost"
export DB_PORT="5432"
export DB_NAME="flow"
export DB_USER="flow_tester"
export DB_PASSWORD="test_password"
export TEMPORAL_HOST="localhost"
export TEMPORAL_PORT=7233
export TEMPORAL_NAMESPACE="flow"

if [[ -f "./.local_envrc" ]]; then
    source ./.local_envrc
fi

# Backwards compatibility with legacy env var names used by other entrypoints.
# Keep these in sync with the canonical DB_* vars above.
# Derive legacy aliases after optional local overrides.
export DB_ADDR="$DB_HOST"
export DB_DATABASE="$DB_NAME"
